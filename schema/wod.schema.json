{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/wodwiz/open-wod-db/schema/wod.schema.json",
  "title": "WOD",
  "type": "object",
  "required": ["id", "name", "category", "format", "movements", "source_notes", "schema_version"],
  "definitions": {
    "format": {
      "type": "string",
      "enum": ["for_time", "amrap", "emom", "tabata", "death_by", "max_effort", "interval", "complex", "max_load", "multi_part"]
    },
    "format_meta": {
      "type": "object",
      "properties": {
        "time_cap_minutes": { "type": ["number", "null"] },
        "interval_seconds": { "type": ["number", "null"] },
        "total_minutes": { "type": ["number", "null"] },
        "work_seconds": { "type": ["number", "null"] },
        "rest_seconds": { "type": ["number", "null"] },
        "rounds": { "type": ["number", "null"] },
        "rest_between_seconds": { "type": ["number", "null"] },
        "scoring": { "type": ["string", "null"], "enum": ["time", "reps", "load", "rounds_reps", null] }
      }
    },
    "movement": {
      "type": "object",
      "required": ["exercise"],
      "properties": {
        "exercise": { "type": "string" },
        "reps": {},
        "distance_m": { "type": ["number", "null"] },
        "load": {
          "type": ["object", "null"],
          "properties": {
            "rx_male": { "type": "string" },
            "rx_female": { "type": "string" }
          }
        },
        "notes": { "type": ["string", "null"] }
      }
    },
    "segment": {
      "type": "object",
      "required": ["format", "movements"],
      "properties": {
        "label": { "type": ["string", "null"] },
        "format": { "$ref": "#/definitions/format" },
        "format_meta": { "$ref": "#/definitions/format_meta" },
        "movements": { "type": "array", "items": { "$ref": "#/definitions/movement" } },
        "scoring": { "type": ["string", "null"], "enum": ["time", "reps", "load", "rounds_reps", null] },
        "rest_after_seconds": { "type": ["number", "null"] },
        "notes": { "type": ["string", "null"] }
      }
    }
  },
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "name": { "type": "string" },
    "category": { "type": "string", "enum": ["girl", "hero", "games", "open", "quarterfinal", "community"] },
    "format": { "$ref": "#/definitions/format" },
    "format_meta": { "$ref": "#/definitions/format_meta" },
    "movements": { "type": "array", "items": { "$ref": "#/definitions/movement" } },
    "segments": {
      "type": "array",
      "items": { "$ref": "#/definitions/segment" }
    },
    "partition": { "type": ["string", "null"], "enum": ["you-go-i-go", "synchro", "shared-reps", null] },
    "scaling": {
      "type": ["object", "null"],
      "properties": {
        "scaled": { "type": "string" },
        "beginner": { "type": "string" }
      }
    },
    "origin": {
      "type": ["object", "null"],
      "properties": {
        "summary": { "type": ["string", "null"] },
        "first_posted": { "type": ["string", "null"] }
      }
    },
    "tags": { "type": "array", "items": { "type": "string" } },
    "description": { "type": ["string", "null"] },
    "source_notes": { "type": "string" },
    "schema_version": { "type": "string" },
    "last_updated": { "type": "string" }
  },
  "allOf": [
    {
      "comment": "A multi_part workout must carry its structure in `segments`.",
      "if": { "required": ["format"], "properties": { "format": { "const": "multi_part" } } },
      "then": { "required": ["segments"], "properties": { "segments": { "minItems": 1 } } }
    }
  ]
}
